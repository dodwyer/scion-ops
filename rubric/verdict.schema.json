{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://livewyer.com/scion-ops/verdict.schema.json",
  "title": "ReviewerVerdict",
  "type": "object",
  "additionalProperties": false,
  "required": ["scores", "verdict"],
  "allOf": [
    {
      "if": {
        "properties": {
          "review_type": { "const": "final" },
          "verdict": { "const": "request_changes" }
        },
        "required": ["review_type", "verdict"]
      },
      "then": {
        "required": ["final_failure_classification", "final_failure_evidence"]
      }
    }
  ],
  "properties": {
    "review_type": {
      "type": "string",
      "enum": ["implementation", "spec", "final", "unknown"],
      "default": "implementation"
    },
    "scores": {
      "type": "object",
      "additionalProperties": false,
      "required": ["correctness", "completeness", "style"],
      "properties": {
        "correctness":  { "type": "integer", "minimum": 1, "maximum": 5 },
        "completeness": { "type": "integer", "minimum": 1, "maximum": 5 },
        "style":        { "type": "integer", "minimum": 1, "maximum": 5 }
      }
    },
    "verdict": {
      "type": "string",
      "enum": ["accept", "request_changes"]
    },
    "blocking_issues": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "final_failure_classification": {
      "type": "string",
      "enum": [
        "implementation_defect",
        "integration_defect",
        "verification_contract",
        "environment_failure",
        "transient_agent_failure"
      ],
      "description": "Required for failed final reviews so the coordinator can route post-integration remediation."
    },
    "final_failure_evidence": {
      "type": "string",
      "description": "Evidence supporting the final-review failure classification."
    },
    "nits": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "change": { "type": "string" },
        "conformance": { "type": "integer", "minimum": 1, "maximum": 5 },
        "spec_completeness": { "type": "integer", "minimum": 1, "maximum": 5 },
        "task_coverage": { "type": "integer", "minimum": 1, "maximum": 5 },
        "operational_verification": { "type": "integer", "minimum": 1, "maximum": 5 },
        "checked_artifacts": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "unresolved_questions": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "gaps": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "summary": {
      "type": "string",
      "description": "One-paragraph human-readable summary of the review."
    }
  }
}
