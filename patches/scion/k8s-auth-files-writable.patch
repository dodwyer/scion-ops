 // defaultSharedDirSize is the default PVC size when not specified in settings.
 const defaultSharedDirSize = "10Gi"
 
+const (
+	k8sAuthFilesMountPath    = "/var/run/scion/auth-files"
+	k8sAgentSecretsMountPath = "/var/run/scion/agent-secrets"
+	k8sCSISecretsMountPath   = "/mnt/secrets-store"
+)
+
+type k8sAuthFileCopy struct {
+	Source string
+	Target string
+}
+
+func k8sResolvedAuthFileCopies(files []api.FileMapping, containerHome string) []k8sAuthFileCopy {
+	copies := make([]k8sAuthFileCopy, 0, len(files))
+	for i, f := range files {
+		copies = append(copies, k8sAuthFileCopy{
+			Source: fmt.Sprintf("%s/auth-file-%d", k8sAuthFilesMountPath, i),
+			Target: expandTildeTarget(f.ContainerPath, containerHome),
+		})
+	}
+	return copies
+}
+
+func k8sAuthSecretFileTarget(s api.ResolvedSecret, containerHome string) (string, bool) {
+	target := expandTildeTarget(s.Target, containerHome)
+	switch {
+	case s.Name == "gcloud-adc" ||
+		strings.HasSuffix(target, "/application_default_credentials.json"),
+		s.Name == "GEMINI_OAUTH_CREDS" ||
+			strings.HasSuffix(target, "/oauth_creds.json"),
+		s.Name == "CLAUDE_AUTH" ||
+			strings.HasSuffix(target, "/.claude/.credentials.json"),
+		s.Name == "CLAUDE_CONFIG" ||
+			strings.HasSuffix(target, "/.claude.json"),
+		s.Name == "CODEX_AUTH" ||
+			strings.HasSuffix(target, "/.codex/auth.json"),
+		s.Name == "OPENCODE_AUTH" ||
+			strings.HasSuffix(target, "/opencode/auth.json"):
+		return target, true
+	default:
+		return "", false
+	}
+}
+
+func k8sAuthFileBootstrapCommand(copies []k8sAuthFileCopy) string {
+	if len(copies) == 0 {
+		return ""
+	}
+
+	var b strings.Builder
+	b.WriteString(`copy_auth_file() {
+  src="$1"
+  dst="$2"
+  if [ ! -f "$src" ]; then
+    echo "missing auth file source: $src" >&2
+    exit 1
+  fi
+  dst_dir="$(dirname "$dst")"
+  owner="${SCION_HOST_UID:-1000}:${SCION_HOST_GID:-1000}"
+  mkdir -p "$dst_dir"
+  cp "$src" "$dst"
+  chmod 600 "$dst" 2>/dev/null || true
+  chown "$owner" "$dst_dir" "$dst" 2>/dev/null || true
+}
+`)
+	for _, copy := range copies {
+		fmt.Fprintf(&b, "copy_auth_file %s %s\n", shellQuoteArg(copy.Source), shellQuoteArg(copy.Target))
+	}
+	return b.String()
+}
